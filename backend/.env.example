# Server Configuration
# Note: Vercel assigns PORT dynamically in production
PORT=5000

# Database Configuration (Supabase PostgreSQL)
# Copy your actual connection strings from Supabase dashboard
DATABASE_URL="postgresql://user:password@host:6543/database?pgbouncer=true&connection_limit=10"
DIRECT_URL="postgresql://user:password@host:5432/database"

# JWT Configuration
# Generate a strong secret for production
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="7d"

# CORS Configuration
# Development: http://localhost:5173 (Vite dev server)
# Production: Set to your Vercel frontend URL (https://your-frontend.vercel.app)
# Multiple origins: separate with commas (no spaces)
CORS_ORIGIN="http://localhost:5173,https://your-frontend.vercel.app"

# Keep-alive (prevents Supabase from pausing by pinging /api/health)
KEEP_ALIVE_ENABLED="true"
KEEP_ALIVE_INTERVAL_HOURS="1"
# Optional: override target URL if needed
# KEEP_ALIVE_URL="http://127.0.0.1:5000/api/health"
